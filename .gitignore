### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml

# Environment
.env
.env.*

# Package lock
frontend/package-lock.json

# Node / Next.js build artifacts
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
*.log
*.tsbuildinfo

# Runtime backups (created by updater sidecar)
data/backups/
data/db-backups/

# Temporary nginx config backups
nginx/*.bak
nginx/*.tmp
# Rendered nginx config — generated at runtime by install.sh apply_nginx_conf
# from nginx.conf.template. Tracking it caused git reset/pull to overwrite the
# admin's working domain config with the placeholder template (lk killed at v5.9.20).
nginx/nginx.conf
nginx/conf.d/*.conf
