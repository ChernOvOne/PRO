// ============================================================
//  HIDEYOU — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ────────────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  telegramId    String?   @unique @map("telegram_id")
  telegramName  String?   @map("telegram_name")
  passwordHash  String?   @map("password_hash")

  remnawaveUuid String?   @unique @map("remnawave_uuid")
  subExpireAt   DateTime? @map("sub_expire_at")
  subStatus     SubStatus @default(INACTIVE) @map("sub_status")
  subLink       String?   @map("sub_link")

  role          Role      @default(USER)
  isActive      Boolean   @default(true) @map("is_active")

  balance       Decimal   @default(0) @map("balance") @db.Decimal(10, 2)
  bonusDays     Int       @default(0) @map("bonus_days")

  referralCode  String    @unique @default(cuid()) @map("referral_code")
  referredById  String?   @map("referred_by_id")
  referredBy    User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]    @relation("Referrals")

  lastIp        String?   @map("last_ip")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // ── Buhgalteria fields (merged from Customer) ───────────
  avatarColor     String?   @map("avatar_color")
  initials        String?
  customerSource  String?   @map("customer_source")
  customerNotes   String?   @map("customer_notes") @db.Text
  totalPaid       Decimal   @default(0) @map("total_paid") @db.Decimal(12, 2)
  paymentsCount   Int       @default(0) @map("payments_count")
  lastPaymentAt   DateTime? @map("last_payment_at")
  currentPlan     String?   @map("current_plan")
  currentPlanTag  String?   @map("current_plan_tag")
  firstSeenAt     DateTime? @map("first_seen_at")

  // Partner link (for investor/partner role users)
  buhPartnerId    String?   @map("buh_partner_id")
  buhPartner      BuhPartner? @relation(fields: [buhPartnerId], references: [id])

  // ── Existing LK relations ──────────────────────────────
  payments           Payment[]
  bonusHistory       ReferralBonus[]
  sessions           Session[]
  importRecord       ImportRecord?
  notifications      Notification[]
  notificationReads  NotificationRead[]
  adminNotesOnUser   AdminNote[]          @relation("AdminNotesOnUser")
  adminNotesBy       AdminNote[]          @relation("AdminNotesBy")
  giftsSent          GiftSubscription[]   @relation("GiftsSent")
  giftsReceived      GiftSubscription[]   @relation("GiftsReceived")
  balanceTransactions BalanceTransaction[]
  emailVerifications EmailVerification[]
  promoUsages        PromoUsage[]
  botMessages        BotMessage[]

  // ── Buhgalteria relations ──────────────────────────────
  buhTransactions    BuhTransaction[]     @relation("BuhTransactionCreator")
  buhInkasRecords    BuhInkasRecord[]     @relation("BuhInkasCreator")
  buhAuditLogs       BuhAuditLog[]
  utmLeads           BuhUtmLead[]

  // ── Bot Constructor relations ──────────────────────────
  userTags           UserTag[]
  userVariables      UserVariable[]

  @@map("users")
}

// ── Sessions ─────────────────────────────────────────────────
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  userAgent String?  @map("user_agent")
  ip        String?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

// ── Tariffs ──────────────────────────────────────────────────
model Tariff {
  id              String      @id @default(uuid())
  name            String
  description     String?
  countries       String?     @map("countries")       // "🇷🇺 Россия, 🇳🇱 Нидерланды, 🇫🇮 Финляндия"
  protocol        String?     @map("protocol")        // "VLESS + XTLS Reality"
  speed           String?     @map("speed")            // "до 1 Гбит/с"
  type            TariffType  @default(SUBSCRIPTION) @map("type")

  // SUBSCRIPTION fields
  durationDays    Int         @default(0) @map("duration_days")
  deviceLimit     Int         @default(3) @map("device_limit")
  trafficGb       Int?        @map("traffic_gb")           // null = unlimited
  trafficStrategy String      @default("MONTH") @map("traffic_strategy")  // MONTH | NO_RESET | WEEK

  // TRAFFIC_ADDON fields
  trafficAddonGb  Int?        @map("traffic_addon_gb")     // GB to add

  // Pricing
  priceRub        Float       @map("price_rub")
  priceUsdt       Float?      @map("price_usdt")

  // Status
  isActive        Boolean     @default(true) @map("is_active")
  isVisible       Boolean     @default(true) @map("is_visible")   // show in user tariff list
  isFeatured      Boolean     @default(false) @map("is_featured")
  isTrial         Boolean     @default(false) @map("is_trial")    // used for trial subscriptions
  sortOrder       Int         @default(0) @map("sort_order")

  // Tariff mode: simple (legacy), variants (multiple durations), configurator (user builds)
  mode            String      @default("simple") @map("mode")
  variants        Json?       @map("variants")       // [{days,priceRub,priceUsdt,label}]
  configurator    Json?       @map("configurator")    // {traffic:{pricePerUnit,min,max,step,default},days:{...},devices:{...}}

  // REMNAWAVE config (for SUBSCRIPTION type)
  remnawaveSquads String[]    @default([]) @map("remnawave_squads")   // Internal squad UUIDs
  remnawaveTag    String?     @map("remnawave_tag")
  remnawaveTagIds String[]    @default([]) @map("remnawave_tag_ids")  // legacy

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  payments          Payment[]
  giftSubscriptions GiftSubscription[]

  @@map("tariffs")
}

// ── Payments ─────────────────────────────────────────────────
model Payment {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id])
  tariffId        String        @map("tariff_id")
  tariff          Tariff        @relation(fields: [tariffId], references: [id])

  provider        PaymentProvider
  providerOrderId String?       @map("provider_order_id")
  amount          Float
  currency        String        @default("RUB")
  status          PaymentStatus @default(PENDING)
  purpose         PaymentPurpose @default(SUBSCRIPTION)

  yukassaPaymentId String?      @map("yukassa_payment_id")
  yukassaStatus   String?       @map("yukassa_status")

  cryptoInvoiceId  Int?         @map("crypto_invoice_id")
  cryptoCurrency   String?      @map("crypto_currency")
  cryptoAmount     String?      @map("crypto_amount")

  confirmedAt     DateTime?     @map("confirmed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  referralBonus      ReferralBonus?
  giftSubscription   GiftSubscription?
  balanceTransactions BalanceTransaction[]

  @@map("payments")
}

// ── Referral bonuses ─────────────────────────────────────────
model ReferralBonus {
  id                   String            @id @default(uuid())
  referrerId           String            @map("referrer_id")
  referrer             User              @relation(fields: [referrerId], references: [id])
  triggeredByPaymentId String            @unique @map("triggered_by_payment_id")
  triggeredByPayment   Payment           @relation(fields: [triggeredByPaymentId], references: [id])
  bonusType            ReferralBonusType @default(DAYS) @map("bonus_type")
  bonusDays            Int               @default(0) @map("bonus_days")
  bonusAmount          Decimal?          @db.Decimal(10, 2) @map("bonus_amount")
  bonusCurrency        String?           @default("RUB") @map("bonus_currency")
  appliedAt            DateTime          @default(now()) @map("applied_at")

  @@map("referral_bonuses")
}

// ── News & Promotions ────────────────────────────────────────
model News {
  id           String    @id @default(uuid())
  type         NewsType  @default(NEWS)
  title        String
  content      String    // markdown
  imageUrl     String?   @map("image_url")
  buttons      Json?     // [{label, url, style}]

  // Promotion-specific
  discountCode String?   @unique @map("discount_code")
  discountPct  Float?    @map("discount_pct")
  discountAbs  Float?    @map("discount_abs")
  tariffIds    String[]  @default([]) @map("tariff_ids")
  maxUses      Int?      @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")

  isActive     Boolean   @default(true) @map("is_active")
  isPinned     Boolean   @default(false) @map("is_pinned")
  publishedAt  DateTime  @default(now()) @map("published_at")
  expiresAt    DateTime? @map("expires_at")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([isActive, publishedAt])
  @@index([type])
  @@map("news")
}

// ── Notifications ────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String?          @map("user_id")
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType @default(INFO)
  title     String
  message   String
  linkUrl   String?          @map("link_url")

  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")

  createdAt DateTime         @default(now()) @map("created_at")

  reads     NotificationRead[]

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ── Notification Read tracking (for broadcasts) ──────────────
model NotificationRead {
  id             String       @id @default(uuid())
  notificationId String       @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now()) @map("read_at")

  @@unique([notificationId, userId])
  @@map("notification_reads")
}

// ── Free Telegram Proxies ────────────────────────────────────
model TelegramProxy {
  id          String   @id @default(uuid())
  name        String
  description String?
  tgLink      String?  @map("tg_link")
  httpsLink   String?  @map("https_link")
  tag         String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("telegram_proxies")
}

// ── Admin Notes ──────────────────────────────────────────────
model AdminNote {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation("AdminNotesOnUser", fields: [userId], references: [id], onDelete: Cascade)
  adminId   String   @map("admin_id")
  admin     User     @relation("AdminNotesBy", fields: [adminId], references: [id], onDelete: Cascade)
  text      String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("admin_notes")
}

// ── Gift Subscriptions ───────────────────────────────────────
model GiftSubscription {
  id              String     @id @default(uuid())
  giftCode        String     @unique @map("gift_code")
  fromUserId      String     @map("from_user_id")
  fromUser        User       @relation("GiftsSent", fields: [fromUserId], references: [id])
  tariffId        String     @map("tariff_id")
  tariff          Tariff     @relation(fields: [tariffId], references: [id])
  paymentId       String     @unique @map("payment_id")
  payment         Payment    @relation(fields: [paymentId], references: [id])

  recipientUserId String?    @map("recipient_user_id")
  recipientUser   User?      @relation("GiftsReceived", fields: [recipientUserId], references: [id])
  recipientEmail  String?    @map("recipient_email")
  message         String?

  status          GiftStatus @default(PENDING)
  claimedAt       DateTime?  @map("claimed_at")
  expiresAt       DateTime   @map("expires_at")

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at")

  @@index([giftCode])
  @@index([fromUserId])
  @@index([recipientUserId])
  @@index([status])
  @@map("gift_subscriptions")
}

// ── Balance Transactions ─────────────────────────────────────
model BalanceTransaction {
  id          String                 @id @default(uuid())
  userId      String                 @map("user_id")
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Decimal                @db.Decimal(10, 2)
  type        BalanceTransactionType
  description String?

  paymentId   String?                @map("payment_id")
  payment     Payment?               @relation(fields: [paymentId], references: [id])

  createdAt   DateTime               @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
  @@map("balance_transactions")
}

// ── Email Verification ───────────────────────────────────────
model EmailVerification {
  id         String                @id @default(uuid())
  userId     String?               @map("user_id")
  user       User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  code       String
  type       EmailVerificationType
  expiresAt  DateTime              @map("expires_at")
  verifiedAt DateTime?             @map("verified_at")

  createdAt  DateTime              @default(now()) @map("created_at")

  @@index([email, code])
  @@index([userId, type])
  @@index([expiresAt])
  @@map("email_verifications")
}

// ── Instruction Platforms ─────────────────────────────────────
model InstructionPlatform {
  id        String             @id @default(uuid())
  slug      String             @unique  // ios | android | windows | macos | linux | tv | router
  name      String                      // "iOS", "Android", ...
  icon      String             @default("📱")  // emoji or SVG name
  sortOrder Int                @default(0) @map("sort_order")
  isActive  Boolean            @default(true) @map("is_active")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  apps      InstructionApp[]

  @@map("instruction_platforms")
}

// ── Instruction Apps ─────────────────────────────────────────
model InstructionApp {
  id          String               @id @default(uuid())
  platformId  String               @map("platform_id")
  platform    InstructionPlatform  @relation(fields: [platformId], references: [id], onDelete: Cascade)

  name        String               // "Happ"
  icon        String               @default("🔵")  // emoji or image URL
  isFeatured  Boolean              @default(false) @map("is_featured")  // рекомендованное
  storeUrl    String?              @map("store_url")   // App Store / Play Market URL
  deeplink    String?              @map("deeplink")    // happ://add/{url}
  sortOrder   Int                  @default(0) @map("sort_order")
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  steps       InstructionStep[]

  @@map("instruction_apps")
}

// ── Instruction Steps ─────────────────────────────────────────
model InstructionStep {
  id        String          @id @default(uuid())
  appId     String          @map("app_id")
  app       InstructionApp  @relation(fields: [appId], references: [id], onDelete: Cascade)

  order     Int
  text      String          // Markdown text
  imageUrl  String?         @map("image_url")  // uploaded image URL
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("instruction_steps")
}

// ── Settings ─────────────────────────────────────────────────
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ── Import tracking ───────────────────────────────────────────
model ImportRecord {
  id               String   @id @default(uuid())
  userId           String?  @unique @map("user_id")
  user             User?    @relation(fields: [userId], references: [id])
  sourceEmail      String?  @map("source_email")
  sourceTelegramId String?  @map("source_telegram_id")
  remnawaveUuid    String?  @map("remnawave_uuid")
  matchedBy        String?  @map("matched_by")
  importedAt       DateTime @default(now()) @map("imported_at")
  status           String   @default("pending")

  @@map("import_records")
}

// ── Promo Codes ──────────────────────────────────────────────
model PromoCode {
  id              String       @id @default(uuid())
  code            String       @unique
  type            String       @default("bonus_days")  // bonus_days | discount | balance | trial
  bonusDays       Int?         @map("bonus_days")
  discountPct     Int?         @map("discount_pct")
  tariffIds       String[]     @default([]) @map("tariff_ids")
  balanceAmount   Float?       @map("balance_amount")
  maxUses         Int?         @map("max_uses")
  usedCount       Int          @default(0) @map("used_count")
  maxUsesPerUser  Int          @default(1) @map("max_uses_per_user")
  expiresAt       DateTime?    @map("expires_at")
  isActive        Boolean      @default(true) @map("is_active")
  description     String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  usages          PromoUsage[]
  @@map("promo_codes")
}

model PromoUsage {
  id        String    @id @default(uuid())
  promoId   String    @map("promo_id")
  promo     PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt    DateTime  @default(now()) @map("used_at")
  @@unique([promoId, userId])
  @@map("promo_usages")
}

// ── Bot Messages ─────────────────────────────────────────────

enum BotMsgDirection {
  IN
  OUT
}

model BotMessage {
  id           String          @id @default(uuid())
  chatId       String          @map("chat_id")
  userId       String?         @map("user_id")
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  direction    BotMsgDirection
  text         String
  buttonsJson  Json?           @map("buttons_json")
  callbackData String?         @map("callback_data")
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([chatId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("bot_messages")
}

// ── Broadcasts ──────────────────────────────────────────────
model Broadcast {
  id            String          @id @default(uuid())
  channel       String          // telegram | email | both
  audience      String          // all | active | inactive | expiring | with_email | with_telegram

  // Telegram message
  tgText        String?         @map("tg_text")
  tgButtons     Json?           @map("tg_buttons")     // [{label, url}]
  tgMediaType   String?         @map("tg_media_type")  // photo | video | animation | document
  tgMediaUrl    String?         @map("tg_media_url")   // uploaded file path or URL
  tgParseMode   String?         @default("Markdown") @map("tg_parse_mode") // Markdown | HTML

  // Poll
  tgPollQuestion String?        @map("tg_poll_question")
  tgPollOptions  Json?          @map("tg_poll_options")    // string[]
  tgPollAnonymous Boolean?      @default(true) @map("tg_poll_anonymous")
  tgPollMultiple  Boolean?      @default(false) @map("tg_poll_multiple")
  tgPollId       String?        @map("tg_poll_id")         // Telegram poll_id from first send

  // Email message
  emailSubject  String?         @map("email_subject")
  emailHtml     String?         @map("email_html")
  emailBtnText  String?         @map("email_btn_text")
  emailBtnUrl   String?         @map("email_btn_url")

  // Status
  status        BroadcastStatus @default(DRAFT)
  scheduledAt   DateTime?       @map("scheduled_at")
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")

  // Stats
  totalRecipients Int           @default(0) @map("total_recipients")
  sentCount       Int           @default(0) @map("sent_count")
  failedCount     Int           @default(0) @map("failed_count")

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("broadcasts")
}

// ── Auto-Funnels ─────────────────────────────────────────────
model Funnel {
  id            String   @id @default(uuid())
  triggerId     String   @unique @map("trigger_id")
  name          String
  description   String?
  enabled       Boolean  @default(false)
  isCustom      Boolean  @default(false) @map("is_custom")
  sortOrder     Int      @default(0) @map("sort_order")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  steps         FunnelStep[]
  logs          FunnelLog[]

  @@map("funnels")
}

model FunnelStep {
  id            String   @id @default(uuid())
  funnelId      String   @map("funnel_id")
  funnel        Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  stepOrder     Int      @default(0) @map("step_order")

  // Delay (from previous step or trigger)
  delayType     String   @default("immediate") @map("delay_type")
  delayValue    Int      @default(0) @map("delay_value")
  delayTime     String?  @map("delay_time")

  // Condition to continue chain
  condition     String   @default("none") @map("condition") // none|not_paid|not_connected|no_subscription|expired

  // Channels
  channelTg     Boolean  @default(false) @map("channel_tg")
  channelEmail  Boolean  @default(false) @map("channel_email")
  channelLk     Boolean  @default(false) @map("channel_lk")

  // TG message
  tgText        String?  @map("tg_text")
  tgButtons     Json?    @map("tg_buttons")
  tgParseMode   String   @default("Markdown") @map("tg_parse_mode")

  // Email
  emailSubject  String?  @map("email_subject")
  emailHtml     String?  @map("email_html")
  emailBtnText  String?  @map("email_btn_text")
  emailBtnUrl   String?  @map("email_btn_url")
  emailTemplate String   @default("dark") @map("email_template")

  // LK notification
  lkTitle       String?  @map("lk_title")
  lkMessage     String?  @map("lk_message")
  lkType        String   @default("INFO") @map("lk_type")

  // Action on send
  actionType    String   @default("none") @map("action_type") // none|bonus_days|balance|promo_discount|promo_balance|trial
  actionValue   Int      @default(0) @map("action_value")     // days, rubles, percent
  actionPromoExpiry Int  @default(7) @map("action_promo_expiry") // promo valid for N days

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([funnelId, stepOrder])
  @@map("funnel_steps")
}

model FunnelLog {
  id        String   @id @default(uuid())
  funnelId  String   @map("funnel_id")
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  stepOrder Int      @default(0) @map("step_order")
  channel   String
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([funnelId, userId, stepOrder])
  @@index([userId, createdAt(sort: Desc)])
  @@map("funnel_logs")
}

// ============================================================
//  BUHGALTERIA MODELS (merged from buhgalteria project)
// ============================================================

// ── Expense/Income Categories ────────────────────────────────
model BuhCategory {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#534AB7")
  icon      String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  transactions     BuhTransaction[]
  autoRules        BuhAutoTagRule[]
  recurringPayments BuhRecurringPayment[]

  @@map("buh_categories")
}

// ── Auto-categorization Rules ────────────────────────────────
model BuhAutoTagRule {
  id         String      @id @default(uuid())
  categoryId String      @map("category_id")
  category   BuhCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  keyword    String

  @@map("buh_auto_tag_rules")
}

// ── Income/Expense Transactions ──────────────────────────────
model BuhTransaction {
  id          String              @id @default(uuid())
  type        BuhTransactionType
  amount      Decimal             @db.Decimal(12, 2)
  date        DateTime            @db.Date
  categoryId  String?             @map("category_id")
  category    BuhCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String?             @db.Text
  receiptUrl  String?             @map("receipt_url") @db.Text
  receiptFile String?             @map("receipt_file")
  isHistorical Boolean            @default(false) @map("is_historical")
  createdById String?             @map("created_by")
  createdBy   User?               @relation("BuhTransactionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  adCampaign  BuhAdCampaign?      @relation("AdCampaignTransaction")
  webhookPayment BuhWebhookPayment? @relation("WebhookPaymentTransaction")

  @@index([date])
  @@index([type])
  @@map("buh_transactions")
}

// ── Partners/Investors ───────────────────────────────────────
model BuhPartner {
  id               String   @id @default(uuid())
  name             String
  roleLabel        String   @map("role_label")
  tgUsername       String?  @map("tg_username")
  tgId            String?  @map("tg_id")
  sharePercent    Float?   @map("share_percent")
  avatarColor     String   @default("#534AB7") @map("avatar_color")
  initials        String?
  notes           String?  @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  initialInvestment Float  @default(0) @map("initial_investment")
  initialReturned   Float  @default(0) @map("initial_returned")
  initialDividends  Float  @default(0) @map("initial_dividends")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  inkasRecords    BuhInkasRecord[]
  adCampaigns     BuhAdCampaign[]
  users           User[]

  @@map("buh_partners")
}

// ── Inkas Records (dividends/returns/investments) ────────────
model BuhInkasRecord {
  id          String         @id @default(uuid())
  partnerId   String         @map("partner_id")
  partner     BuhPartner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  type        BuhInkasType
  amount      Decimal        @db.Decimal(12, 2)
  date        DateTime       @db.Date
  monthLabel  String?        @map("month_label")
  description String?        @db.Text
  createdById String?        @map("created_by")
  createdBy   User?          @relation("BuhInkasCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("buh_inkas_records")
}

// ── VPN Servers (infrastructure payment tracking) ────────────
model BuhVpnServer {
  id              String           @id @default(uuid())
  name            String
  provider        String?
  ipAddress       String?          @map("ip_address")
  purpose         String?
  panelUrl        String?          @map("panel_url") @db.Text
  monthlyCost     Decimal?         @map("monthly_cost") @db.Decimal(12, 2)
  currency        String           @default("RUB")
  paymentDay      Int?             @map("payment_day")
  nextPaymentDate DateTime?        @map("next_payment_date") @db.Date
  status          BuhServerStatus  @default(ACTIVE)
  notifyDaysBefore Int             @default(5) @map("notify_days_before")
  isActive        Boolean          @default(true) @map("is_active")
  notes           String?          @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  recurringPayments BuhRecurringPayment[]

  @@map("buh_vpn_servers")
}

// ── Ad Campaigns (marketing + UTM tracking) ──────────────────
model BuhAdCampaign {
  id               String      @id @default(uuid())
  date             DateTime    @db.Date
  channelName      String?     @map("channel_name")
  channelUrl       String?     @map("channel_url") @db.Text
  format           String?
  amount           Decimal     @db.Decimal(12, 2)
  subscribersGained Int?       @map("subscribers_gained")
  screenshotUrl    String?     @map("screenshot_url") @db.Text
  notes            String?     @db.Text
  budgetSource     String      @default("account") @map("budget_source") // account | investment | stats_only
  investorPartnerId String?    @map("investor_partner_id")
  investorPartner  BuhPartner? @relation(fields: [investorPartnerId], references: [id], onDelete: SetNull)
  transactionId    String?     @unique @map("transaction_id")
  transaction      BuhTransaction? @relation("AdCampaignTransaction", fields: [transactionId], references: [id], onDelete: SetNull)
  utmCode          String      @unique @map("utm_code")
  targetUrl        String?     @map("target_url") @db.Text
  targetType       String      @default("bot") @map("target_type") // bot | channel | custom
  createdById      String?     @map("created_by")
  createdAt        DateTime    @default(now()) @map("created_at")

  @@map("buh_ad_campaigns")
}

// ── Recurring Payments ───────────────────────────────────────
model BuhRecurringPayment {
  id          String       @id @default(uuid())
  name        String
  categoryId  String?      @map("category_id")
  category    BuhCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount      Decimal      @db.Decimal(12, 2)
  currency    String       @default("RUB")
  paymentDay  Int          @map("payment_day")
  description String?      @db.Text
  serverId    String?      @map("server_id")
  server      BuhVpnServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("buh_recurring_payments")
}

// ── Monthly Statistics (manual) ──────────────────────────────
model BuhMonthlyStats {
  id             String   @id @default(uuid())
  year           Int
  month          Int
  onlineCount    Int?     @map("online_count")
  onlineWeekly   Int?     @map("online_weekly")
  pdpInChannel   Int?     @map("pdp_in_channel")
  avgCheck       Decimal? @map("avg_check") @db.Decimal(12, 2)
  totalPayments  Int?     @map("total_payments")
  totalRefunds   Decimal? @map("total_refunds") @db.Decimal(12, 2)
  tagPaid        Int?     @map("tag_paid")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([year, month])
  @@map("buh_monthly_stats")
}

// ── Business Milestones ──────────────────────────────────────
model BuhMilestone {
  id            String    @id @default(uuid())
  title         String
  targetAmount  Decimal   @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(12, 2)
  type          String    @default("revenue") // revenue | profit | investment_return
  isCompleted   Boolean   @default(false) @map("is_completed")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("buh_milestones")
}

// ── Audit Log ────────────────────────────────────────────────
model BuhAuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // create | update | delete
  entity    String   // transaction | partner | category | ...
  entityId  String?  @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("buh_audit_logs")
}

// ── Notification Channels (Telegram alerts) ──────────────────
model BuhNotificationChannel {
  id            String   @id @default(uuid())
  name          String
  chatId        String   @map("chat_id")
  isActive      Boolean  @default(true) @map("is_active")
  notifyIncome  Boolean  @default(true) @map("notify_income")
  notifyExpense Boolean  @default(true) @map("notify_expense")
  notifyInkas   Boolean  @default(true) @map("notify_inkas")
  notifyPayment Boolean  @default(true) @map("notify_payment")
  notifyAd      Boolean  @default(true) @map("notify_ad")
  notifyServer  Boolean  @default(true) @map("notify_server")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("buh_notification_channels")
}

// ── UTM Click tracking ───────────────────────────────────────
model BuhUtmClick {
  id        String   @id @default(uuid())
  utmCode   String   @map("utm_code")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  referer   String?  @db.Text
  country   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([utmCode])
  @@map("buh_utm_clicks")
}

// ── UTM Leads ────────────────────────────────────────────────
model BuhUtmLead {
  id           String   @id @default(uuid())
  utmCode      String   @map("utm_code")
  customerId   String?  @map("customer_id")
  customer     User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String?  @map("customer_name")
  username     String?
  extraData    Json?    @map("extra_data")
  converted    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([utmCode])
  @@index([customerId])
  @@map("buh_utm_leads")
}

// ── Webhook API Keys ─────────────────────────────────────────
model BuhWebhookApiKey {
  id           String    @id @default(uuid())
  name         String
  key          String    @unique
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsed     DateTime? @map("last_used")
  requestCount Int       @default(0) @map("request_count")

  webhookPayments BuhWebhookPayment[]

  @@map("buh_webhook_api_keys")
}

// ── Webhook Payments (from external bots) ────────────────────
model BuhWebhookPayment {
  id            String    @id @default(uuid())
  externalId    String?   @unique @map("external_id")
  apiKeyId      String?   @map("api_key_id")
  apiKey        BuhWebhookApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("RUB")
  customerEmail String?   @map("customer_email")
  customerId    String?   @map("customer_id")
  customerName  String?   @map("customer_name")
  plan          String?
  planTag       String?   @map("plan_tag")
  subStart      DateTime? @map("sub_start") @db.Date
  subEnd        DateTime? @map("sub_end") @db.Date
  description   String?   @db.Text
  rawData       Json?     @map("raw_data")
  source        String?
  transactionId String?   @unique @map("transaction_id")
  transaction   BuhTransaction? @relation("WebhookPaymentTransaction", fields: [transactionId], references: [id], onDelete: SetNull)
  date          DateTime  @db.Date
  utmCode       String?   @map("utm_code")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("buh_webhook_payments")
}

// ============================================================
//  BOT CONSTRUCTOR MODELS (no-code visual flow builder)
// ============================================================

model BotBlockGroup {
  id        String     @id @default(uuid())
  name      String
  icon      String?
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  blocks    BotBlock[]
  @@map("bot_block_groups")
}

model BotBlock {
  id        String        @id @default(uuid())
  name      String
  groupId   String?       @map("group_id")
  group     BotBlockGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  type      BotBlockType
  text          String?   @db.Text
  mediaUrl      String?   @map("media_url") @db.Text
  mediaType     String?   @map("media_type")
  parseMode     String    @default("Markdown") @map("parse_mode")
  pinMessage    Boolean   @default(false) @map("pin_message")
  deletePrev    String    @default("none") @map("delete_prev")
  replyKeyboard Json?     @map("reply_keyboard")
  removeReplyKb Boolean   @default(false) @map("remove_reply_kb")
  conditionType   String?  @map("condition_type")
  conditionValue  String?  @map("condition_value")
  conditionLogic  String   @default("AND") @map("condition_logic")
  conditions      Json?
  nextBlockTrue   String?  @map("next_block_true")
  nextBlockFalse  String?  @map("next_block_false")
  actionType    String?  @map("action_type")
  actionValue   String?  @map("action_value")
  nextBlockId   String?  @map("next_block_id")
  inputPrompt     String?  @map("input_prompt") @db.Text
  inputVar        String?  @map("input_var")
  inputValidation String?  @map("input_validation")
  delayMinutes  Int?     @map("delay_minutes")
  delayUnit     String   @default("minutes") @map("delay_unit")
  splitVariants Json?    @map("split_variants")
  redirectBlockId String? @map("redirect_block_id")
  reactionEmoji String?  @map("reaction_emoji")
  notifyAdminText String? @map("notify_admin_text") @db.Text
  httpMethod    String?  @map("http_method")
  httpUrl       String?  @map("http_url") @db.Text
  httpHeaders   Json?    @map("http_headers")
  httpBody      String?  @map("http_body") @db.Text
  httpSaveVar   String?  @map("http_save_var")
  emailSubject  String?  @map("email_subject")
  emailBody     String?  @map("email_body") @db.Text
  paymentTitle       String?  @map("payment_title")
  paymentDescription String?  @map("payment_description") @db.Text
  paymentAmount      Int?     @map("payment_amount")
  paymentPayload     String?  @map("payment_payload")
  messageEffectId String?  @map("message_effect_id")
  streamingText   String?  @map("streaming_text") @db.Text
  giftId          String?  @map("gift_id")
  funnelId        String?  @map("funnel_id")
  throttleMinutes Int?     @map("throttle_minutes")
  scheduleStart   String?  @map("schedule_start")
  scheduleEnd     String?  @map("schedule_end")
  scheduleDays    Json?    @map("schedule_days")
  scheduleBlockId String?  @map("schedule_block_id")
  posX          Float    @default(0) @map("pos_x")
  posY          Float    @default(0) @map("pos_y")
  isDraft       Boolean  @default(true) @map("is_draft")
  version       Int      @default(1)
  publishedAt   DateTime? @map("published_at")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  buttons       BotButton[]
  triggers      BotTrigger[]
  stats         BotBlockStat[]
  @@index([groupId])
  @@index([type])
  @@map("bot_blocks")
}

model BotButton {
  id          String   @id @default(uuid())
  blockId     String   @map("block_id")
  block       BotBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  label       String
  type        String   @default("block")
  nextBlockId String?  @map("next_block_id")
  url         String?  @db.Text
  copyText    String?  @map("copy_text") @db.Text
  style              String?
  iconCustomEmojiId  String?  @map("icon_custom_emoji_id")
  row         Int      @default(0)
  col         Int      @default(0)
  sortOrder   Int      @default(0) @map("sort_order")
  clickCount  Int      @default(0) @map("click_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@index([blockId])
  @@map("bot_buttons")
}

model BotTrigger {
  id        String   @id @default(uuid())
  type      String
  value     String
  blockId   String   @map("block_id")
  block     BotBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  priority  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([type, value])
  @@index([type])
  @@map("bot_triggers")
}

model BotBlockStat {
  id       String   @id @default(uuid())
  blockId  String   @map("block_id")
  block    BotBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  views    Int      @default(0)
  clicks   Int      @default(0)
  dropoffs Int      @default(0)
  @@unique([blockId, date])
  @@map("bot_block_stats")
}

model UserTag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       String
  createdAt DateTime @default(now()) @map("created_at")
  @@unique([userId, tag])
  @@index([tag])
  @@map("user_tags")
}

model UserVariable {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([userId, key])
  @@index([key])
  @@map("user_variables")
}

enum BotBlockType {
  MESSAGE
  CONDITION
  ACTION
  INPUT
  DELAY
  SPLIT
  REDIRECT
  PAYMENT
  MEDIA_GROUP
  EFFECT
  REACTION
  STREAMING
  GIFT
  HTTP
  EMAIL
  NOTIFY_ADMIN
  ASSIGN
  FUNNEL
}

